<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
    Hardened-runtime entitlements required when codesigning a Wine-based app
    for Developer ID distribution + notarization. Each permission is needed
    for a specific Wine subsystem; commenting any out will cause subprocess
    crashes at runtime or notarization rejection.
    -->

    <!-- Wine's preloader uses dyld env vars (DYLD_FALLBACK_LIBRARY_PATH,
         DYLD_INSERT_LIBRARIES) to inject its loader into Win32 processes. -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>

    <!-- Rosetta 2 (running x86_64 Win32 binaries) and Wine's PE loader both
         allocate JIT pages and write executable code into them. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Wine loads its own PE/ELF .dll and .so files that aren't signed by
         our team. Library validation would block those loads. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Allow ptrace-style debugging (needed by wineserver to manage child
         Win32 processes' memory and registers). -->
    <key>com.apple.security.cs.disable-executable-page-protection</key>
    <true/>

    <!-- Bottle lives in ~/Library/Application Support/D4Mac/ and we need to
         read/write the Battle.net + Diablo IV install there. -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
</dict>
</plist>
